---
layout: layouts/base.njk
---

{% from "components/component.njk" import component with context %}
<div class="fr-container">
  <div class="fr-grid-row">
    <div class="fr-col-12 fr-col-md-4">
      {% set navContext = eleventyNavigation.nav | getNavigationContext %}
      {% set navCollection = collections[navContext.collectionName] %}
      {% set navLinks = navCollection | filterCollectionLang | eleventyNavigation %}
      {% set parentPage = null %}
      {% for p in navCollection %}
        {% if p.data.eleventyNavigation.key == eleventyNavigation.parent %}
          {% set parentPage = p %}
        {% endif %}
      {% endfor %}
      {% if parentPage and parentPage.data.eleventyNavigation.parent %}
        {% set ancestorPage = null %}
        {% for p in navCollection %}
          {% if p.data.eleventyNavigation.key == parentPage.data.eleventyNavigation.parent %}
            {% set ancestorPage = p %}
          {% endif %}
        {% endfor %}
        {% set parentData = ancestorPage.data if ancestorPage else parentPage.data %}
      {% elif parentPage %}
        {% set parentData = parentPage.data %}
      {% else %}
        {% set parentData = null %}
      {% endif %}
      {% set sidemenuTitle = navContext.title %}
      {% set sidemenuActive = eleventyNavigation.sidemenuActive %}
      {% include "templates/sidemenu.njk" %}
    </div>
    <div id="contenu" class="fr-col-12 fr-col-md-8 fr-py-12v">
      <div class="fr-grid-row" data-pagefind-ignore>
        <div class="fr-col-12">
          {% if showBreadcrumb %}
            {% include "components/breadcrumb.njk" %}
          {% endif %}
          {% include "components/published_on.njk" %}
          <div class="fr-grid-row fr-grid-row--gutters fr-mb-2v">
            {% if parentData and parentData.image %}
              <div class="fr-col-auto" style="width: 150px; height: 150px; overflow: hidden;">
                <img src="{{ parentData.image.src }}"
                    alt="{{ parentData.image.alt }}"
                    style="width: 100%; height: 100%; object-fit: cover; object-position: center; border-radius: 8px;">
              </div>
            {% endif %}
            <div class="fr-col">
              <h1 class="fr-mb-2v">{{ parentData.title if parentData and parentData.title else title }}</h1>
              {% if parentData and parentData.tags %}
                {% set tags = parentData.tags %}
                {% set small_tags = true %}
                  {% include "components/taggroup-disabled.njk" %}
              {% endif %}
              {% if parentData and parentData.description %}
                <p class="fr-text--bold">{{ parentData.description }}</p>
              {% endif %}
            </div>
          </div>
          {% if parentData and parentData.quote %}
            <div class="fr-grid-row fr-grid-row--gutters">
              <span class="fr-col-auto fr-icon-quote-fill fr-icon--lg fr-text-title--blue-france" aria-hidden="true"></span>
              <p class="fr-col">{{ parentData.quote }}</p>
            </div>
          {% endif %}
        </div>
      </div>
      {% if eleventyNavigation.parent and (not parentData or eleventyNavigation.parent != parentData.title) %}
        <h2 class="fr-mt-2v" data-pagefind-ignore>{{ eleventyNavigation.parent }}</h2>
        <h3 class="fr-mt-2v"{% if title == "Découverte de l’offre produit"%} data-pagefind-ignore{% endif %}>{{ title }}</h3>
      {% else %}
        <h2 class="fr-mt-2v"{% if title == "Découverte de l’offre produit"%} data-pagefind-ignore{% endif %}>{{ title }}</h2>
      {% endif %}
      {% if summary.visible %}
        {% set depth = summary.depth | default(1) %}
        {% set summaryItems = content | getSummaryItems(depth) %}
        {% include "components/summary.njk" %}
      {% endif %}
      {{ content | safe }}
      {% if showPageSwitcher %}
        {% include "components/page_switcher.njk" %}
      {% endif %}
    </div>
  </div>
</div>