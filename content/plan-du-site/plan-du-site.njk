<p>Ce plan de site ne décrit que la section aide de cartes.gouv.fr. Le plan général du site se trouve ici : <a href="https://cartes.gouv.fr/plan-du-site"> Plan du site</a></p>

{% macro renderTree(node) %}
  <ul data-pagefind-ignore>
    {% for segment, data in node %}
      <li>
        {% if data.__page %}
          <a href="{{ data.__page.url }}">{{ data.__page.data.title or data.__page.fileSlug }}</a>
        {% else %}
          {{ segment }}
        {% endif %}
        {% if data.__children and (data.__children | length) > 0 %}
          {{ renderTree(data.__children) }}
        {% endif %}
      </li>
    {% endfor %}
  </ul>
{% endmacro %}

